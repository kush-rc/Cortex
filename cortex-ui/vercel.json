{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://cortex-vf38.onrender.com/api/:path*"
        },
        {
            "source": "/static/:path*",
            "destination": "https://cortex-vf38.onrender.com/static/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}